local function createBtn(text, pos, isSave)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 28)
    btn.Position = pos
    btn.BackgroundColor3 = isSave and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(10, 20, 60)
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.LuckiestGuy
    btn.TextSize = 13
    btn.ZIndex = 5
    btn.Parent = mainFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local bs = Instance.new("UIStroke", btn)
    bs.Color = isSave and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(0, 100, 220)
    bs.Thickness = 1
    return btn
end

local fovBtn       = createBtn("FOV: OFF",          UDim2.new(0.075, 0, 0, 46))
local galaxyBtn    = createBtn("GALAXY MODE: OFF",  UDim2.new(0.075, 0, 0, 82))
local antiBatBtn   = createBtn("ANTI BAT: OFF",     UDim2.new(0.075, 0, 0, 118))
local antiFlingBtn = createBtn("ANTI-FLING: OFF",   UDim2.new(0.075, 0, 0, 154))
local saveBtn      = createBtn("SAVE CONFIG",       UDim2.new(0.075, 0, 0, 200), true)

--- LOGIC VARIABLES ---
local fovOn, galaxyOn, antiBatOn, antiFlingOn = false, false, false, false
local detectDistance = 15
local defBrightness, defClock, defAmbient = Lighting.Brightness, Lighting.ClockTime, Lighting.OutdoorAmbient

local BLUE_ON  = Color3.fromRGB(0, 100, 255)
local BLUE_OFF = Color3.fromRGB(10, 20, 60)

local function updateAntiFling()
    antiFlingBtn.Text = antiFlingOn and "ANTI-FLING: ON" or "ANTI-FLING: OFF"
    antiFlingBtn.BackgroundColor3 = antiFlingOn and BLUE_ON or BLUE_OFF
end

local function updateGalaxy()
    galaxyBtn.Text = galaxyOn and "GALAXY MODE: ON" or "GALAXY MODE: OFF"
    galaxyBtn.BackgroundColor3 = galaxyOn and BLUE_ON or BLUE_OFF
    if galaxyOn then
        local sky = Lighting:FindFirstChild("GalaxySky") or Instance.new("Sky")
        sky.Name = "GalaxySky"
        sky.SkyboxBk = "rbxassetid://159454299"
        sky.SkyboxDn = "rbxassetid://159454296"
        sky.SkyboxFt = "rbxassetid://159454293"
        sky.SkyboxLf = "rbxassetid://159454286"
        sky.SkyboxRt = "rbxassetid://159454289"
        sky.SkyboxUp = "rbxassetid://159454291"
        sky.Parent = Lighting
        Lighting.Brightness = 0
        Lighting.ClockTime = 0
        Lighting.ExposureCompensation = -2
        Lighting.OutdoorAmbient = Color3.fromRGB(0, 0, 0)
    else
        if Lighting:FindFirstChild("GalaxySky") then Lighting.GalaxySky:Destroy() end
        Lighting.Brightness = defBrightness
        Lighting.ClockTime = defClock
        Lighting.ExposureCompensation = 0
        Lighting.OutdoorAmbient = defAmbient
    end
end

-- Toggles
fovBtn.MouseButton1Click:Connect(function()
    fovOn = not fovOn
    camera.FieldOfView = fovOn and 100 or 70
    fovBtn.Text = fovOn and "FOV: ON" or "FOV: OFF"
    fovBtn.BackgroundColor3 = fovOn and BLUE_ON or BLUE_OFF
end)

galaxyBtn.MouseButton1Click:Connect(function()
    galaxyOn = not galaxyOn
    updateGalaxy()
end)

antiBatBtn.MouseButton1Click:Connect(function()
    antiBatOn = not antiBatOn
    antiBatBtn.Text = antiBatOn and "ANTI BAT: ON" or "ANTI BAT: OFF"
    antiBatBtn.BackgroundColor3 = antiBatOn and BLUE_ON or BLUE_OFF
end)

antiFlingBtn.MouseButton1Click:Connect(function()
    antiFlingOn = not antiFlingOn
    updateAntiFling()
end)

-- Star twinkle animation
local t = 0
RunService.RenderStepped:Connect(function(dt)
    t = t + dt
    for i, s in ipairs(stars) do
        local alpha = (math.sin(t * s.speed * 60 + s.phase) + 1) / 2
        s.label.TextTransparency = 0.2 + (1 - alpha) * 0.7
    end
end)

-- Loops
RunService.Stepped:Connect(function()
    if antiFlingOn and player.Character then
        for _, obj in pairs(player.Character:GetDescendants()) do
            if obj:IsA("BasePart") then obj.CanCollide = false end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end

    local currentTool = char:FindFirstChildOfClass("Tool")
    local holdingBat  = currentTool and currentTool.Name:lower():find("bat")

    if not antiBatOn or holdingBat then
        local spin = root:FindFirstChild("AuraForce")
        if spin then spin:Destroy() hum.AutoRotate = true end
        return
    end

    local threat = false
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= player and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            if (root.Position - other.Character.HumanoidRootPart.Position).Magnitude <= detectDistance then
                threat = true break
            end
        end
    end

    local spin = root:FindFirstChild("AuraForce")
    if threat then
        if not spin then
            local bv = Instance.new("BodyAngularVelocity")
            bv.Name = "AuraForce"
            bv.MaxTorque = Vector3.new(0, math.huge, 0)
            bv.AngularVelocity = Vector3.new(0, 50, 0)
            bv.Parent = root
            hum.AutoRotate = false
        end
    elseif spin then
        spin:Destroy()
        hum.AutoRotate = true
    end
end)

-- Save Config
saveBtn.MouseButton1Click:Connect(function()
    if writefile then
        local data = {
            FOV = fovOn, Galaxy = galaxyOn, AntiBat = antiBatOn, AntiFling = antiFlingOn,
            PosX = mainFrame.Position.X.Scale, OffsetX = mainFrame.Position.X.Offset,
            PosY = mainFrame.Position.Y.Scale, OffsetY = mainFrame.Position.Y.Offset
        }
        writefile(FILE_NAME, HttpService:JSONEncode(data))
        saveBtn.Text = "SAVED!"
        task.wait(0.8)
        saveBtn.Text = "SAVE CONFIG"
    end
end)

-- Load Config
if isfile and isfile(FILE_NAME) then
    local s, d = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
    if s and d then
        if d.PosX then mainFrame.Position = UDim2.new(d.PosX, d.OffsetX, d.PosY, d.OffsetY) end
        fovOn, galaxyOn, antiBatOn, antiFlingOn = d.FOV or false, d.Galaxy or false, d.AntiBat or false, d.AntiFling or false
        if fovOn then camera.FieldOfView = 100 fovBtn.Text = "FOV: ON" fovBtn.BackgroundColor3 = BLUE_ON end
        if antiBatOn then antiBatBtn.Text = "ANTI BAT: ON" antiBatBtn.BackgroundColor3 = BLUE_ON end
        updateGalaxy()
        updateAntiFling()
    end
end
