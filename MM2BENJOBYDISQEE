local function GetCharacter() return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait() end
local function GetHRP()       return GetCharacter():WaitForChild("HumanoidRootPart")             end

local function FindNearestCoin()
    local root = GetHRP()
    local best, bestD = nil, math.huge
    for _, obj in pairs(workspace:GetChildren()) do
        local cc = obj:FindFirstChild("CoinContainer")
        if cc then
            for _, coin in pairs(cc:GetChildren()) do
                if coin:IsA("BasePart") and coin:FindFirstChild("TouchInterest") then
                    local d = (root.Position - coin.Position).Magnitude
                    if d < bestD then bestD = d best = coin end
                end
            end
        end
    end
    return best, bestD
end

local function FindNearestCandy()
    local root = GetHRP()
    local best, bestD = nil, math.huge
    for _, obj in pairs(workspace:GetChildren()) do
        local cc = obj:FindFirstChild("CoinContainer")
        if cc then
            for _, candy in pairs(cc:GetChildren()) do
                if candy:IsA("BasePart") and candy:GetAttribute("CoinID") == "Candy" and candy:FindFirstChild("TouchInterest") then
                    local d = (root.Position - candy.Position).Magnitude
                    if d < bestD then bestD = d best = candy end
                end
            end
        end
    end
    if not best then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name == "candy" then
                local d = (root.Position - obj.Position).Magnitude
                if d < bestD then bestD = d best = obj end
            end
        end
    end
    return best, bestD
end

