local function GradText(text, c1, c2)
    local out, len = "", #text
    for i = 1, len do
        local p = (i-1) / math.max(len-1, 1)
        local r = math.floor((c1.R + (c2.R - c1.R) * p) * 255)
        local g = math.floor((c1.G + (c2.G - c1.G) * p) * 255)
        local b = math.floor((c1.B + (c2.B - c1.B) * p) * 255)
        out = out .. string.format('<font color="rgb(%d,%d,%d)">%s</font>', r, g, b, text:sub(i,i))
    end
    return out
end

