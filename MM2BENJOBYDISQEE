    if not inventoryMain then return end
    for _, cat in pairs(inventoryMain.Weapons.Items.Container:GetChildren()) do
        for _, folder in pairs(cat.Container:GetChildren()) do
            if folder.Name == "Christmas" or folder.Name == "Halloween" then
                for _, item in pairs(folder.Container:GetChildren()) do
                    if item:IsA("Frame") and item.ItemName.Label.Text == selectedWeaponName then
                        local num = tonumber((item.Container.Amount.Text):match("x(%d+)"))
                        item.Container.Amount.Text = num and ("x"..(num+1)) or "x2"
                    end
                end
            elseif folder:IsA("Frame") and folder.ItemName and folder.ItemName.Label.Text == selectedWeaponName then
                local num = tonumber((folder.Container.Amount.Text):match("x(%d+)"))
                folder.Container.Amount.Text = num and ("x"..(num+1)) or "x2"
            end
        end
    end
end

local function DuplicateInventory()
    wait(math.random(3,5))
    if not inventoryMain then return end
    local function dup(frame)
        if not frame.ItemName then return end
        local name = frame.ItemName.Label and frame.ItemName.Label.Text
        if name == "Default Knife" or name == "Default Gun" then return end
        if not frame.Container or not frame.Container.Amount then return end
        local num = tonumber((frame.Container.Amount.Text):match("x(%d+)"))
        frame.Container.Amount.Text = num and ("x"..(num*2)) or "x2"
    end
    for _, cat in pairs(inventoryMain.Weapons.Items.Container:GetChildren()) do
        for _, folder in pairs(cat.Container:GetChildren()) do
            if folder.Name == "Christmas" or folder.Name == "Halloween" then
                for _, item in pairs(folder.Container:GetChildren()) do if item:IsA("Frame") then dup(item) end end
            elseif folder:IsA("Frame") then dup(folder) end
        end
    end
    for _, pet in pairs(inventoryMain.Pets.Items.Container.Current.Container:GetChildren()) do
        if pet:IsA("Frame") and pet.Container and pet.Container.Amount then
            local num = tonumber((pet.Container.Amount.Text):match("x(%d+)"))
            pet.Container.Amount.Text = num and ("x"..(num*2)) or "x2"
        end
    end
end

