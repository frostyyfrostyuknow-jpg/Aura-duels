local function StartESP()
    if espConnection then espConnection:Disconnect() end
    espConnection = RunService.Heartbeat:Connect(function()
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local char = player.Character
            if not char then
                ClearHighlight(nil)
                ClearLine(player)
                continue
            end
            local should, role = ShouldHighlight(player)
            local color = role and GetRoleColor(role) or Colors.Ghost
            if highlightEnabled and should then
                ApplyHighlight(char, color)
            else
                ClearHighlight(char)
            end
            if lineESPEnabled and should then
                ApplyLine(player, color)
            else
                ClearLine(player)
            end
        end
    end)
end

local function StopESP()
    if espConnection then espConnection:Disconnect() espConnection = nil end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character then ClearHighlight(player.Character) end
            ClearLine(player)
        end
    end
end

local function RefreshESP()
    if highlightEnabled or lineESPEnabled then StartESP() else StopESP() end
end

