local function GetBottomCenter()
    local vp = workspace.CurrentCamera.ViewportSize
    return Vector2.new(vp.X / 2, vp.Y)
end

local function ApplyLine(player, color)
    if not player.Character then return end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
    local line = lineESPObjects[player]
    if not line then
        line = Drawing.new("Line")
        line.Thickness = 2
        lineESPObjects[player] = line
    end
    line.Color   = color
    line.From    = GetBottomCenter()
    line.To      = Vector2.new(pos.X, pos.Y)
    line.Visible = onScreen
    line.Transparency = 1
end

local function ClearLine(player)
    if lineESPObjects[player] then
        lineESPObjects[player]:Destroy()
        lineESPObjects[player] = nil
    end
end

