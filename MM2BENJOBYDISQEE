local function FlingPlayers(playerNames)
    local flingAll = false
    local function GetFromName(name)
        name = name:lower()
        if name == "all" or name == "others" then flingAll = true return end
        if name == "random" then
            local all = Players:GetPlayers()
            for i = #all, 1, -1 do if all[i] == LocalPlayer then table.remove(all, i) end end
            return all[math.random(#all)]
        end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                if p.Name:lower():match("^"..name) or p.DisplayName:lower():match("^"..name) then return p end
            end
        end
    end

    local function DoFling(tp)
        local lc = LocalPlayer.Character
        local lh = lc and lc:FindFirstChildOfClass("Humanoid")
        local lr = lh and lh.RootPart
        if not lc or not lh or not lr then return end
        local tc = tp.Character
        local th = tc:FindFirstChildOfClass("Humanoid")
        local tr = th and th.RootPart
        local tH = tc:FindFirstChild("Head")
        if th and th.Sit and not flingAll then return end
        if lr.Velocity.Magnitude < 50 then getgenv().OldPos = lr.CFrame end
        if tH then workspace.CurrentCamera.CameraSubject = tH
        elseif th and tr then workspace.CurrentCamera.CameraSubject = th end

        local function Tp(part, off, rot)
            lr.CFrame = CFrame.new(part.Position) * off * rot
            lc:SetPrimaryPartCFrame(CFrame.new(part.Position) * off * rot)
            lr.Velocity = Vector3.new(9e8,9e8,9e8)
            lr.RotVelocity = Vector3.new(9e8,9e8,9e8)
        end
        local function PerformFling(part)
            local spin, st = 0, tick()
            while lr do
                if not th then break end
                if part.Velocity.Magnitude < 50 then
                    spin += 100
                    Tp(part, CFrame.new(0,1.5,0)+th.MoveDirection*part.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(spin),0,0)) task.wait()
                    Tp(part, CFrame.new(0,-1.5,0)+th.MoveDirection*part.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(spin),0,0)) task.wait()
                    Tp(part, CFrame.new(2.25,1.5,-2.25)+th.MoveDirection*part.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(spin),0,0)) task.wait()
                    Tp(part, CFrame.new(-2.25,-1.5,2.25)+th.MoveDirection*part.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(spin),0,0)) task.wait()
                else
                    Tp(part, CFrame.new(0,1.5,th.WalkSpeed),  CFrame.Angles(math.rad(90),0,0)) task.wait()
                    Tp(part, CFrame.new(0,-1.5,-th.WalkSpeed), CFrame.Angles(0,0,0))            task.wait()
                end
                if part.Velocity.Magnitude > 500  then break end
                if part.Parent ~= tc              then break end
                if tp.Parent   ~= Players         then break end
                if tp.Character ~= tc             then break end
                if th.Sit or lh.Health <= 0       then break end
                if tick() > st + 2                then break end
            end
        end

        workspace.FallenPartsDestroyHeight = 0/0
        local bv = Instance.new("BodyVelocity")
        bv.Name = "BenjoVel" bv.Parent = lr
        bv.Velocity  = Vector3.new(9e8,9e8,9e8)
        bv.MaxForce  = Vector3.new(math.huge,math.huge,math.huge)
        lh:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        if tr and tH then
            if (tr.CFrame.p - tH.CFrame.p).Magnitude > 5 then PerformFling(tH) else PerformFling(tr) end
        elseif tr then PerformFling(tr)
        elseif tH then PerformFling(tH) end
        bv:Destroy()
        lh:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        workspace.CurrentCamera.CameraSubject = lh
        repeat
            lr.CFrame = getgenv().OldPos * CFrame.new(0,0.5,0)
            lc:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0,0.5,0))
            lh:ChangeState("GettingUp")
            for _, part in pairs(lc:GetChildren()) do
                if part:IsA("BasePart") then part.Velocity = Vector3.zero part.RotVelocity = Vector3.zero end
            end
            task.wait()
        until (lr.Position - getgenv().OldPos.p).Magnitude < 25
        workspace.FallenPartsDestroyHeight = -500
    end

    if not playerNames[1] then return end
    if flingAll then
        for _, p in pairs(Players:GetPlayers()) do DoFling(p) end
    else
        for _, name in pairs(playerNames) do
            local t = GetFromName(name)
            if t and t ~= LocalPlayer then DoFling(t) end
        end
    end
end

local function FlingMurderer()
    local m = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and GetPlayerRole(p) == "Murderer" then m = p break end
