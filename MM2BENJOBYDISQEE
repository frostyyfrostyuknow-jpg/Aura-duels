WReplTab:Input({ Flag="FromWeapon", Title="Weapon to Replace", Desc="Current weapon", Placeholder="e.g. Blossom", Callback=function(v) fromWeapon=v end })
WReplTab:Space()
WReplTab:Input({ Flag="ToWeapon", Title="Weapon to Receive", Desc="Desired appearance", Placeholder="e.g. Chroma", Callback=function(v) toWeapon=v end })
WReplTab:Space()
WReplTab:Button({ Title="Change Visual", Icon="wand-2", Color=Colors.Purple, Justify="Center", Callback=function()
    if fromWeapon=="" or toWeapon=="" then
        WindUI:Notify({ Title="Error", Content="Enter both weapon names!", Icon="x-circle", Duration=5 }) return end
    local ok=pcall(function()
        local db=require(ReplicatedStorage.Database.Sync.Item)
        local froms, tos={},{}
        for name in pairs(db) do
            if WeaponNameMatches(name,fromWeapon) then table.insert(froms,name) end
            if WeaponNameMatches(name,toWeapon)   then table.insert(tos,  name) end
        end
        assert(#froms>0 and #tos>0,"not found")
        for _,f in ipairs(froms) do for _,t in ipairs(tos) do
            db[f]={}
            for k,v in pairs(db[t]) do db[f][k]=v end
            ReplicatedStorage.Remotes.Inventory.Equip:FireServer(t)
        end end
    end)
    WindUI:Notify({ Title=ok and "Success" or "Error", Content=ok and "Visual changed!" or "Failed!", Icon=ok and "check-circle" or "x-circle", Duration=5 }) end })

